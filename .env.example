# 应用模式：local（离线兜底） / cloud（强制走 Supabase）
NEXT_PUBLIC_APP_MODE=local

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # 仅服务端使用，绝不能给前端
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase 数据库连接（仅给 scripts/migrate.ts 跑 migration 用，可选）
# 格式：postgres://postgres:<PASSWORD>@db.<REF>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# 豆包 / Seedream
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=
SEEDREAM_API_KEY=
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-260128
DOUBAO_IMAGE_SIZE=2K
